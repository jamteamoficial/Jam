# Copia este archivo a .env.local y rellena con tu proyecto de Supabase.
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
#
# Usa la clave "anon" / "public" (NO la service_role).
# Si aparece "Invalid API key", vuelve a copiar URL + anon y reinicia: npm run dev

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...pega_aqui_la_anon_completa

# Opcional: URL pública del sitio (p. ej. https://tu-app.vercel.app). Útil si algún flujo corre sin window.
# NEXT_PUBLIC_SITE_URL=https://TU-DOMINIO.vercel.app

# OAuth Google — en Supabase: Authentication → URL Configuration → Redirect URLs
# Añade EXACTAMENTE (incluye http/https y puerto):
#   http://localhost:3000/auth/callback
#   https://TU-DOMINIO.vercel.app/auth/callback
#
# En Google Cloud Console → APIs & Services → Credentials → OAuth 2.0:
#   Authorized redirect URIs debe incluir la URL que te da Supabase, por ejemplo:
#   https://TU-PROYECTO.supabase.co/auth/v1/callback
